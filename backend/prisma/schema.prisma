generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  passwordHash  String
  name          String
  phone         String?
  verified      Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  properties    Property[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Property {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String?
  address     String
  type        PropertyType
  surface     Float
  antiquity   Int?
  condition   PropertyCondition?
  status      PropertyStatus     @default(VACANT)
  contract    Contract?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

enum PropertyType {
  APARTMENT
  HOUSE
  COMMERCIAL
  PH
}

enum PropertyCondition {
  EXCELLENT
  GOOD
  REGULAR
  NEEDS_WORK
}

enum PropertyStatus {
  VACANT
  OCCUPIED
  IN_ARREARS
  EXPIRING_SOON
}

model Contract {
  id                 String              @id @default(cuid())
  propertyId         String              @unique
  property           Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  startDate          DateTime
  endDate            DateTime
  initialAmount      Float
  currentAmount      Float
  paymentDay         Int
  indexType          IndexType
  adjustFrequency    Int
  nextAdjustDate     DateTime
  tenant             Tenant?
  payments           Payment[]
  adjustmentHistory  AdjustmentHistory[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

enum IndexType {
  IPC
  ICL
}

model Tenant {
  id         String     @id @default(cuid())
  contractId String     @unique
  contract   Contract   @relation(fields: [contractId], references: [id], onDelete: Cascade)
  name       String
  email      String
  phone      String?
  linkToken  String     @unique @default(cuid())
  claims     Claim[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Claim {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  category    ClaimCategory
  description String
  photoUrl    String?
  status      ClaimStatus   @default(OPEN)
  priority    ClaimPriority @default(MEDIUM)
  history     ClaimHistory[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum ClaimCategory {
  PLUMBING
  ELECTRICITY
  STRUCTURE
  OTHER
}

enum ClaimStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum ClaimPriority {
  HIGH
  MEDIUM
  LOW
}

model ClaimHistory {
  id        String      @id @default(cuid())
  claimId   String
  claim     Claim       @relation(fields: [claimId], references: [id])
  oldStatus ClaimStatus
  newStatus ClaimStatus
  comment   String?
  changedAt DateTime    @default(now())
}

model Payment {
  id         String        @id @default(cuid())
  contractId String
  contract   Contract      @relation(fields: [contractId], references: [id], onDelete: Cascade)
  amount     Float
  period     String
  dueDate    DateTime
  paidDate   DateTime?
  status     PaymentStatus @default(PENDING)
  method     String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

enum PaymentStatus {
  PENDING
  PAID
  LATE
}

model AdjustmentHistory {
  id             String    @id @default(cuid())
  contractId     String
  contract       Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  indexType      IndexType
  previousAmount Float
  newAmount      Float
  variation      Float
  appliedAt      DateTime  @default(now())
  notified       Boolean   @default(false)
}
